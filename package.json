{
  "name": "pixelrpg",
  "version": "0.0.1",
  "description": "Experimental tile based map editor",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "yarn workspaces foreach -v -W -t run build",
    "check": "yarn workspaces foreach -v -W -t run check",
    "check:barrels-clean": "yarn workspaces foreach -v -W -t run build:barrels && git diff --exit-code -- '**/index.ts'",
    "format:barrels": "yarn workspaces foreach -v -W -t run build:barrels && biome format --write .",
    "test": "yarn workspaces foreach -v -W --include @pixelrpg/engine run test",
    "start": "yarn workspace @pixelrpg/maker-gjs run start",
    "clear": "yarn workspaces foreach -v --parallel -W run clear",
    "format": "yarn format:barrels && biome check . --write --unsafe",
    "lint": "biome check .",
    "prepare": "husky",
    "git:merge-upstream": "yarn workspaces foreach -v --parallel -A run git:merge-upstream"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "games/*"
  ],
  "resolutions": {
    "excalibur": "^0.32.0",
    "@girs/adw-1": "^1.10.0-4.0.0-rc.7",
    "@girs/cairo-1.0": "^1.0.0-4.0.0-rc.7",
    "@girs/freetype2-2.0": "^2.0.0-4.0.0-rc.7",
    "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.7",
    "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.0-rc.7",
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.7",
    "@girs/gjs": "^4.0.0-rc.7",
    "@girs/glib-2.0": "^2.88.0-4.0.0-rc.7",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.7",
    "@girs/graphene-1.0": "^1.0.0-4.0.0-rc.7",
    "@girs/gsk-4.0": "^4.0.0-4.0.0-rc.7",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.7",
    "@girs/gtksource-5": "^5.20.0-4.0.0-rc.7",
    "@girs/harfbuzz-0.0": "^13.2.1-4.0.0-rc.7",
    "@girs/pango-1.0": "^1.57.1-4.0.0-rc.7",
    "@girs/pangocairo-1.0": "^1.0.0-4.0.0-rc.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "barrelsby": "^2.8.1",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@girs/gtksource-5": "^5.20.0-4.0.0-rc.7"
  },
  "dependenciesMeta": {
    "@gjsify/webgl@0.1.11": {
      "unplugged": true
    }
  }
}
