{
    "name": "@pixelrpg/maker-gjs",
    "version": "0.0.1",
    "description": "PixelRPG Maker for GNOME",
    "main": "src/main.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "clear": "rm -rf dist",
        "build:vite": "vite build",
        "build:resources": "glib-compile-resources org.pixelrpg.maker.data.gresource.xml",
        "build:barrels": "barrelsby --delete --directory src src/widgets src/objects",
        "build": "yarn build:resources && yarn build:barrels && yarn build:vite",
        "check": "tsc",
        "start": "gjs -m dist/main.js",
        "start:debug": "GTK_DEBUG=interactive gjs -m dist/main.js"
    },
    "keywords": [
        "pixelrpg",
        "maker",
        "gnome",
        "gjs"
    ],
    "author": "Pascal Garber <pascal@artandcode.studio>",
    "license": "GPL-3.0",
    "devDependencies": {
        "@gjsify/vite-plugin-blueprint": "^0.2.2",
        "barrelsby": "^2.8.1",
        "lightningcss": "^1.30.1",
        "typescript": "^5.9.2",
        "vite": "^7.1.3"
    },
    "dependencies": {
        "@girs/adw-1": "^1.8.0-4.0.0-beta.36",
        "@girs/gdk-4.0": "^4.0.0-4.0.0-beta.36",
        "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.0-beta.36",
        "@girs/gio-2.0": "^2.84.4-4.0.0-beta.36",
        "@girs/gjs": "^4.0.0-beta.36",
        "@girs/glib-2.0": "^2.84.4-4.0.0-beta.36",
        "@girs/gobject-2.0": "^2.84.4-4.0.0-beta.36",
        "@girs/gtk-4.0": "^4.19.1-4.0.0-beta.36",
        "@girs/javascriptcore-6.0": "^2.48.5-4.0.0-beta.36",
        "@girs/webkit-6.0": "^2.48.5-4.0.0-beta.36",
        "@pixelrpg/data-core": "workspace:^",
        "@pixelrpg/data-gjs": "workspace:^",
        "@pixelrpg/engine-core": "workspace:^",
        "@pixelrpg/engine-gjs": "workspace:^",
        "@pixelrpg/message-channel-core": "workspace:^",
        "@pixelrpg/message-channel-gjs": "workspace:^",
        "@pixelrpg/ui-gjs": "workspace:^",
        "mime": "^4.0.7"
    }
}
