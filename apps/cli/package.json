{
    "name": "@pixelrpg/cli",
    "version": "0.0.1",
    "description": "PixelRPG CLI tools",
    "type": "module",
    "private": true,
    "main": "src/main.js",
    "bin": {
        "pixelrpg": "./src/main.js"
    },
    "scripts": {
        "build": "node esbuild.js",
        "start": "node dist/main.js",
        "dev": "node --experimental-specifier-resolution=bundler --experimental-strip-types src/main.ts"
    },
    "dependencies": {
        "@excaliburjs/plugin-tiled": "^0.32.0",
        "@pixelrpg/data": "workspace:^",
        "esbuild": "^0.28.0",
        "fast-xml-parser": "^5.6.0",
        "jsdom": "^29.0.2",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.12.2",
        "@types/yargs": "^17.0.35",
        "typescript": "^6.0.2"
    }
}
