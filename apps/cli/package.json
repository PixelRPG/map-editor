{
    "name": "@pixelrpg/cli",
    "version": "0.0.1",
    "description": "PixelRPG CLI tools",
    "type": "module",
    "private": true,
    "main": "src/main.js",
    "bin": {
        "pixelrpg": "./src/main.js"
    },
    "scripts": {
        "build": "node esbuild.js",
        "start": "node dist/main.js",
        "dev": "node --experimental-specifier-resolution=bundler --experimental-strip-types src/main.ts"
    },
    "dependencies": {
        "@excaliburjs/plugin-tiled": "workspace:^",
        "@pixelrpg/data-excalibur": "workspace:^",
        "esbuild": "^0.25.10",
        "fast-xml-parser": "^5.2.5",
        "jsdom": "^27.0.0",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/jsdom": "^21.1.7",
        "@types/node": "^24.5.2",
        "@types/yargs": "^17.0.33",
        "typescript": "^5.9.2"
    }
}
