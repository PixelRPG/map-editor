{
  "name": "@pixelrpg/storybook-gjs",
  "version": "0.1.0",
  "description": "Storybook for PixelRPG GTK Widgets",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist org.pixelrpg.storybook",
    "build:barrels": "gjsify barrels src src/types src/widgets",
    "check:barrels": "gjsify barrels --check src src/types src/widgets",
    "build:app": "gjsify build src/main.ts --app gjs --globals auto,dom --shebang --outfile org.pixelrpg.storybook",
    "build": "gjsify run build:barrels && gjsify run build:app",
    "check": "gjsify run build:barrels && tsc",
    "start": "gjsify run org.pixelrpg.storybook",
    "start:debug": "GTK_DEBUG=interactive gjsify run org.pixelrpg.storybook"
  },
  "dependencies": {
    "@girs/adw-1": "^1.10.0-4.0.4",
    "@girs/gdk-4.0": "^4.0.0-4.0.4",
    "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.4",
    "@girs/gio-2.0": "^2.88.0-4.0.4",
    "@girs/gjs": "^4.0.4",
    "@girs/glib-2.0": "^2.88.0-4.0.4",
    "@girs/gobject-2.0": "^2.88.0-4.0.4",
    "@girs/gtk-4.0": "^4.23.0-4.0.4",
    "@gjsify/dom-elements": "^0.7.2",
    "@pixelrpg/games-zelda-like": "workspace:^",
    "@pixelrpg/gjs": "workspace:^",
    "@pixelrpg/story-gjs": "workspace:^"
  },
  "devDependencies": {
    "@gjsify/cli": "^0.7.2",
    "typescript": "^6.0.3"
  }
}
