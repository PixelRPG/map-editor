{
    "name": "@pixelrpg/storybook-gjs",
    "version": "0.1.0",
    "description": "Storybook for PixelRPG GTK Widgets",
    "main": "src/main.ts",
    "type": "module",
    "scripts": {
        "clear": "rm -rf dist org.pixelrpg.storybook",
        "check": "tsc",
        "build:barrels": "barrelsby --delete --directory src src/types src/widgets",
        "build:app": "gjsify build src/main.ts --app gjs --globals dom --shebang --outfile org.pixelrpg.storybook",
        "build": "yarn build:barrels && yarn build:app",
        "start": "gjsify run org.pixelrpg.storybook",
        "start:debug": "GTK_DEBUG=interactive gjsify run org.pixelrpg.storybook"
    },
    "dependencies": {
        "@girs/adw-1": "^1.10.0-4.0.0-rc.4",
        "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.4",
        "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.0-rc.4",
        "@girs/gio-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gjs": "^4.0.0-rc.4",
        "@girs/glib-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.4",
        "@gjsify/dom-elements": "^0.1.11",
        "@pixelrpg/games-zelda-like": "workspace:^",
        "@pixelrpg/gjs": "workspace:^",
        "@pixelrpg/story-gjs": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "^0.1.11",
        "barrelsby": "^2.8.1",
        "typescript": "^6.0.2"
    }
}
