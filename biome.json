{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "useNamingConvention": "off",
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.yarn",
      "!**/.pnp.*",
      "!**/refs",
      "!**/games/zelda-like/maps",
      "!**/games/zelda-like/spritesets",
      "!**/*.gresource",
      "!**/*.ui",
      "!**/.*",
      "!apps/maker-gjs/data",
      "!**/*.blp",
      "!**/*.xml",
      "!**/*.css"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": false
  }
}