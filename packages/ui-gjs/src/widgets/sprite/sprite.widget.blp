using Gtk 4.0;
using Adw 1;

template $SpriteWidget: Adw.Bin {
    hexpand: false;
    vexpand: false;
    halign: center;
    valign: center;
    
    child: Gtk.Picture image {
        can-shrink: false;
        keep-aspect-ratio: true;
        content-fit: fill;
        hexpand: false;
        vexpand: false;
        halign: fill;
        valign: fill;
    };
}
