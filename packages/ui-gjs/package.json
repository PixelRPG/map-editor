{
    "name": "@pixelrpg/ui-gjs",
    "version": "0.1.0",
    "type": "module",
    "main": "src/index.ts",
    "exports": {
        "./index.css": "./src/index.css",
        "./sprite": "./src/sprite/index.ts",
        ".": "./src/index.ts"
    },
    "scripts": {
        "check": "tsc",
        "build:barrels": "barrelsby --delete --directory src src/widgets src/widgets/map-editor src/widgets/sprite",
        "build": "yarn build:barrels"
    },
    "dependencies": {
        "@pixelrpg/data": "workspace:^",
        "@pixelrpg/story-gjs": "workspace:^"
    },
    "devDependencies": {
        "@girs/adw-1": "^1.10.0-4.0.0-rc.4",
        "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.4",
        "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.0-rc.4",
        "@girs/gio-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gjs": "^4.0.0-rc.4",
        "@girs/glib-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.4",
        "@girs/pango-1.0": "^1.57.1-4.0.0-rc.4",
        "barrelsby": "^2.8.1",
        "typescript": "^6.0.2",
        "vite": "^8.0.8"
    }
