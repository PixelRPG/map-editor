{
    "name": "@pixelrpg/message-channel-core",
    "version": "0.0.1",
    "description": "Common package to share code between GJS and the WebVew",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "check": "tsc --noEmit",
        "build:barrels": "barrelsby --delete --directory src/polyfills src/types src/utils",
        "build": "yarn build:barrels"
    },
    "exports": {
        ".": "./src/index.ts",
        "./env": "./src/env.ts"
    },
    "author": "Pascal Garber <pascal@artandcode.studio>",
    "license": "MIT",
    "devDependencies": {
        "barrelsby": "^2.8.1",
        "typescript": "^5.9.2"
    }
}
