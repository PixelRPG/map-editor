{
    "name": "@pixelrpg/engine-excalibur",
    "version": "0.0.1",
    "description": "Excalibur.js engine wrapper for the PixelRPG map editor",
    "main": "src/index.ts",
    "types": "index.d.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "clear": "rm -rf dist tsconfig.tsbuildinfo",
        "build:barrels": "barrelsby --delete --directory src/systems src/components src/services src/scenes",
        "build": "yarn build:barrels && tsc --noEmit",
        "check": "tsc --noEmit"
    },
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./src/index.ts"
        },
        "./package.json": "./package.json"
    },
    "author": "Pascal Garber <pascal@artandcode.studio>",
    "license": "MIT",
    "devDependencies": {
        "barrelsby": "^2.8.1",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@excaliburjs/plugin-tiled": "workspace:^",
        "@pixelrpg/data": "workspace:^",
        "excalibur": "workspace:^"
    }
}
