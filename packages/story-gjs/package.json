{
  "name": "@pixelrpg/story-gjs",
  "version": "0.1.0",
  "description": "GJS Implementation of the Storybook functionality for PixelRPG",
  "main": "src/index.ts",
  "scripts": {
    "check": "tsc",
    "build:blueprints": "blueprint-compiler compile src/widgets/story.widget.blp --output src/widgets/story.widget.ui",
    "build": "gjsify run build:blueprints",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@girs/adw-1": "^1.10.0-4.0.0-rc.15",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.15",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.15"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
