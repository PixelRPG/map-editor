{
  "compilerOptions": {   
    "lib": ["ESNext", "DOM"],
    "types": [],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "typeRoots": ["./node_modules/@types", "./"]
  },
  "files": [
    "src/index.ts",
  ],
  "include": [
    "src/**/*",
    "env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}