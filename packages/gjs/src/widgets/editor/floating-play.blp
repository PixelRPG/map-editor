using Gtk 4.0;
using Adw 1;

template $PixelRpgFloatingPlay : Adw.Bin {
  halign: end;
  valign: end;
  margin-end: 12;
  margin-bottom: 12;

  Gtk.Button play_button {
    action-name: "win.play";
    tooltip-text: _("Play");
    styles ["suggested-action", "pill"]

    child: Gtk.Box {
      spacing: 4;
      margin-start: 4;
      margin-end: 4;

      Gtk.Image {
        icon-name: "media-playback-start-symbolic";
      }

      Gtk.Label {
        label: _("Play");
      }
    };
  }
}
