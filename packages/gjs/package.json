{
    "name": "@pixelrpg/gjs",
    "version": "0.0.1",
    "description": "GJS (GTK/Adwaita) widgets, previews, and Gio file helpers for the PixelRPG map editor",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "check": "tsc",
        "build:barrels": "barrelsby --delete --directory src/widgets/map-editor src/widgets/sprite",
        "build": "yarn build:barrels"
    },
    "exports": {
        "./index.css": "./src/index.css",
        "./stories": "./src/stories.ts",
        ".": "./src/index.ts"
    },
    "dependencies": {
        "@gjsify/canvas2d": "^0.1.12",
        "@gjsify/dom-elements": "^0.1.12",
        "@gjsify/event-bridge": "^0.1.12",
        "@gjsify/webgl": "^0.1.12",
        "@pixelrpg/engine": "workspace:*",
        "@pixelrpg/story-gjs": "workspace:^",
        "excalibur": "^0.32.0"
    },
    "devDependencies": {
        "@girs/adw-1": "^1.10.0-4.0.0-rc.4",
        "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.4",
        "@girs/gdkpixbuf-2.0": "^2.0.0-4.0.0-rc.4",
        "@girs/gio-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gjs": "^4.0.0-rc.4",
        "@girs/glib-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.4",
        "@girs/graphene-1.0": "^1.0.0-4.0.0-rc.4",
        "@girs/gsk-4.0": "^4.0.0-4.0.0-rc.4",
        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.4",
        "@girs/gtksource-5": "^5.20.0-4.0.0-rc.4",
        "@girs/pango-1.0": "^1.57.1-4.0.0-rc.4",
        "barrelsby": "^2.8.1",
        "typescript": "^6.0.2",
        "vite": "^8.0.8"
    }
}
