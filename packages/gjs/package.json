{
  "name": "@pixelrpg/gjs",
  "version": "0.0.1",
  "description": "GJS (GTK/Adwaita) widgets, previews, and Gio file helpers for the PixelRPG map editor",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build:barrels": "gjsify barrels src/widgets/common src/widgets/editor src/widgets/sprite",
    "check:barrels": "gjsify barrels --check src/widgets/common src/widgets/editor src/widgets/sprite",
    "build": "gjsify run build:barrels",
    "check": "gjsify run build:barrels && tsc",
    "test": "gjsify test",
    "storybook": "gjsify storybook"
  },
  "gjsify": {
    "storybook": {
      "applicationId": "org.pixelrpg.storybook",
      "title": "PixelRPG Storybook",
      "globals": "auto,dom"
    }
  },
  "exports": {
    "./index.css": "./src/index.css",
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@gjsify/canvas2d": "^0.8.0",
    "@gjsify/dom-elements": "^0.8.0",
    "@gjsify/event-bridge": "^0.8.0",
    "@gjsify/storybook": "^0.8.0",
    "@gjsify/webgl": "^0.8.0",
    "@pixelrpg/engine": "workspace:*",
    "excalibur": "^0.32.0"
  },
  "devDependencies": {
    "@girs/adw-1": "1.10.0-4.0.4",
    "@girs/gdk-4.0": "4.0.0-4.0.4",
    "@girs/gdkpixbuf-2.0": "2.0.0-4.0.4",
    "@girs/gio-2.0": "2.88.0-4.0.4",
    "@girs/gjs": "4.0.4",
    "@girs/glib-2.0": "2.88.0-4.0.4",
    "@girs/gobject-2.0": "2.88.0-4.0.4",
    "@girs/graphene-1.0": "1.0.0-4.0.4",
    "@girs/gsk-4.0": "4.0.0-4.0.4",
    "@girs/gtk-4.0": "4.23.0-4.0.4",
    "@girs/gtksource-5": "5.20.0-4.0.4",
    "@girs/pango-1.0": "1.57.1-4.0.4",
    "@gjsify/cli": "^0.8.0",
    "typescript": "^6.0.3"
  }
}
