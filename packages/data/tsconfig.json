{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "outDir": "./dist",
    "lib": ["dom", "dom.iterable", "es5", "ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["env.d.ts", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
