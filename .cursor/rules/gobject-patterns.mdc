## Modern Graphics (GSK-first)

```ts
vfunc_snapshot(s: Gtk.Snapshot): void {
  const { x, y, w, h } = this._sprite;
  s.push_clip(new Graphene.Rect({ x:0, y:0, width:w, height:h }));
  s.save(); s.translate(new Graphene.Point({ x:-x, y:-y }));
  s.append_texture(this._sheet, new Graphene.Rect({ x:0, y:0, width:this._sheet.get_width(), height:this._sheet.get_height() }));
  s.restore(); s.pop();
}
```

> Prefer GPU composition. Only use `Gdk.MemoryTexture` + `download()` when you **must** touch pixels.

