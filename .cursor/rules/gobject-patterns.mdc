## Properties & Signals (minimal patterns)

```ts
// Properties
export class MyWidget extends Gtk.Widget {
  static {
    GObject.registerClass({
      GTypeName: 'MyWidget',
      Properties: {
        value: GObject.ParamSpec.int('value','Value','', GObject.ParamFlags.READWRITE, 0, 100, 0),
      },
      Signals: { 'done': {} },
    }, this);
  }
  set value(v: number) { this.set_property('value', v); } // optional sugar
  get value() { return this.get_property('value') as number; }
  _finish() { this.emit('done'); }
}
```

```blp
// Bind + signal in Blueprint
Label { label: bind template.value as <string>; }
Button { clicked => $_finish(); }
```

